# Clerk Authentication - https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: Clerk URLs (defaults work for dev)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/rider/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/rider/dashboard

# Google Maps JavaScript API - https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Backend API base URL (if you have one)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
